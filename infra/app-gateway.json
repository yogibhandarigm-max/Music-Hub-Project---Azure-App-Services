{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.44.1.10279",
      "templateHash": "4226604657859427150"
    }
  },
  "parameters": {
    "appGatewayName": {
      "type": "string"
    },
    "appGatewayPublicIpName": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "subnetId": {
      "type": "string"
    },
    "backendFqdn": {
      "type": "string"
    },
    "useHttps": {
      "type": "bool",
      "defaultValue": false
    },
    "frontendCertificateData": {
      "type": "securestring",
      "defaultValue": ""
    },
    "frontendCertificatePassword": {
      "type": "securestring",
      "defaultValue": ""
    }
  },
  "variables": {
    "frontendPortName": "[if(parameters('useHttps'), 'appGatewayFrontendPortHttps', 'appGatewayFrontendPortHttp')]",
    "listenerProtocol": "[if(parameters('useHttps'), 'Https', 'Http')]",
    "frontendPortValue": "[if(parameters('useHttps'), 443, 80)]"
  },
  "resources": [
    {
      "type": "Microsoft.Network/publicIPAddresses",
      "apiVersion": "2023-05-01",
      "name": "[parameters('appGatewayPublicIpName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard"
      },
      "properties": {
        "publicIPAllocationMethod": "Static"
      }
    },
    {
      "type": "Microsoft.Network/applicationGateways",
      "apiVersion": "2025-07-01",
      "name": "[parameters('appGatewayName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "WAF_v2",
        "tier": "WAF_v2",
        "capacity": 2
      },
      "properties": {
        "gatewayIPConfigurations": [
          {
            "name": "appGatewayIpConfig",
            "properties": {
              "subnet": {
                "id": "[parameters('subnetId')]"
              }
            }
          }
        ],
        "frontendIPConfigurations": [
          {
            "name": "appGatewayFrontendIP",
            "properties": {
              "publicIPAddress": {
                "id": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('appGatewayPublicIpName'))]"
              }
            }
          }
        ],
        "frontendPorts": [
          {
            "name": "[variables('frontendPortName')]",
            "properties": {
              "port": "[variables('frontendPortValue')]"
            }
          }
        ],
        "backendAddressPools": [
          {
            "name": "appGatewayBackendPool",
            "properties": {
              "backendAddresses": [
                {
                  "fqdn": "[parameters('backendFqdn')]"
                }
              ]
            }
          }
        ],
        "backendHttpSettingsCollection": [
          {
            "name": "appGatewayBackendHttpSettings",
            "properties": {
              "port": 443,
              "protocol": "Https",
              "pickHostNameFromBackendAddress": true,
              "requestTimeout": 30
            }
          }
        ],
        "sslCertificates": "[if(parameters('useHttps'), createArray(createObject('name', 'appGatewaySslCert', 'properties', createObject('data', parameters('frontendCertificateData'), 'password', parameters('frontendCertificatePassword')))), createArray())]",
        "httpListeners": [
          {
            "name": "appGatewayHttpListener",
            "properties": {
              "frontendIPConfiguration": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/frontendIPConfigurations', parameters('appGatewayName'), 'appGatewayFrontendIP')]"
              },
              "frontendPort": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/frontendPorts', parameters('appGatewayName'), variables('frontendPortName'))]"
              },
              "protocol": "[variables('listenerProtocol')]",
              "sslCertificate": "[if(parameters('useHttps'), createObject('id', resourceId('Microsoft.Network/applicationGateways/sslCertificates', parameters('appGatewayName'), 'appGatewaySslCert')), null())]"
            }
          }
        ],
        "requestRoutingRules": [
          {
            "name": "appGatewayRoutingRule",
            "properties": {
              "ruleType": "Basic",
              "httpListener": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/httpListeners', parameters('appGatewayName'), 'appGatewayHttpListener')]"
              },
              "backendAddressPool": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/backendAddressPools', parameters('appGatewayName'), 'appGatewayBackendPool')]"
              },
              "backendHttpSettings": {
                "id": "[resourceId('Microsoft.Network/applicationGateways/backendHttpSettingsCollection', parameters('appGatewayName'), 'appGatewayBackendHttpSettings')]"
              }
            }
          }
        ],
        "webApplicationFirewallConfiguration": {
          "enabled": true,
          "firewallMode": "Prevention",
          "ruleSetType": "OWASP",
          "ruleSetVersion": "3.2"
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Network/publicIPAddresses', parameters('appGatewayPublicIpName'))]"
      ]
    }
  ],
  "outputs": {
    "appGatewayId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/applicationGateways', parameters('appGatewayName'))]"
    },
    "appGatewayPublicIpId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Network/publicIPAddresses', parameters('appGatewayPublicIpName'))]"
    }
  }
}